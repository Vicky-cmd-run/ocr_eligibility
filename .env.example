# Database
DATABASE_URL=postgresql+asyncpg://ocr_user:ocr_password@db:5432/ocr_db
SYNC_DATABASE_URL=postgresql://ocr_user:ocr_password@db:5432/ocr_db

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# File Storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# OCR
OCR_CONFIDENCE_AUTO_THRESHOLD=0.90
OCR_CONFIDENCE_REVIEW_THRESHOLD=0.75
PADDLEOCR_LANG=en
PADDLEOCR_USE_GPU=false

# Processing
CELERY_CONCURRENCY=4
MAX_BATCH_SIZE=1000
PDF_DPI=200

# Cutoff Formula: pcm_average | engineering_200
CUTOFF_FORMULA=pcm_average

# Math Mode: combined | simple_average
MATH_MODE=combined

# Eligibility threshold (strict greater-than)
ELIGIBILITY_THRESHOLD=50.0

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# App
APP_ENV=development
SECRET_KEY=change-me-in-production
LOG_LEVEL=INFO
